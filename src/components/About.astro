										</svg>
									</div>
									<div>
										<div class="font-semibold text-slate-900">Tailwind CSS</div>
										<div class="text-sm text-slate-600">Utility-first</div>
									</div>
								</div>
							</div>
							
							<div class="group p-4 bg-slate-50 hover:bg-green-50 rounded-xl transition-all duration-300 hover:-translate-y-1 border border-slate-100 hover:border-green-200">
								<div class="flex items-center gap-3">
									<div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
										<svg class="w-5 h-5 text-blue-600" fill="currentColor" viewBox="0 0 24 24">
											<path d="M5.8 11.9c0 2.023 1.577 3.6 3.6 3.6s3.6-1.577 3.6-3.6V8.4c0-2.023-1.577-3.6-3.6-3.6S5.8 6.377 5.8 8.4v3.5zm6.6-7.5c0-2.023 1.577-3.6 3.6-3.6s3.6 1.577 3.6 3.6-1.577 3.6-3.6 3.6-3.6-1.577-3.6-3.6zm-3 15.6c-2.023 0-3.6-1.577-3.6-3.6s1.577-3.6 3.6-3.6 3.6 1.577 3.6 3.6-1.577 3.6-3.6 3.6zm6.6-3.6c0 2.023 1.577 3.6 3.6 3.6s3.6-1.577 3.6-3.6-1.577-3.6-3.6-3.6-3.6 1.577-3.6 3.6z"/>
										</svg>
									</div>
									<div>
										<div class="font-semibold text-slate-900">MySQL</div>
										<div class="text-sm text-slate-600">Relational DB</div>
									</div>
								</div>
							</div>
							
							<div class="group p-4 bg-slate-50 hover:bg-green-50 rounded-xl transition-all duration-300 hover:-translate-y-1 border border-slate-100 hover:border-green-200">
								<div class="flex items-center gap-3">
									<div class="w-10 h-10 bg-yellow-100 rounded-lg flex items-center justify-center">
