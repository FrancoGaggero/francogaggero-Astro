									</div>
								</div>
							</div>
							
							<div class="group p-4 bg-slate-50 hover:bg-green-50 rounded-xl transition-all duration-300 hover:-translate-y-1 border border-slate-100 hover:border-green-200">
								<div class="flex items-center gap-3">
									<div class="w-10 h-10 bg-cyan-100 rounded-lg flex items-center justify-center">
										<svg class="w-5 h-5 text-cyan-600" fill="currentColor" viewBox="0 0 24 24">
