---
import GradualBlur from './GradualBlur.jsx';
---

<section class="min-h-screen bg-slate-950 text-white flex items-center relative overflow-hidden" id="hero">
	<!-- Fondo con grid sutil -->
	<div class="absolute inset-0 bg-[linear-gradient(rgba(148,163,184,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(148,163,184,0.03)_1px,transparent_1px)] bg-[size:60px_60px]"></div>

	<!-- Gradient orbs -->
	<div class="absolute inset-0 overflow-hidden">
		<div class="absolute top-1/4 -left-32 w-[500px] h-[500px] bg-blue-600/15 rounded-full blur-[120px] hero-orb-1"></div>
		<div class="absolute bottom-1/4 -right-32 w-[400px] h-[400px] bg-violet-600/15 rounded-full blur-[120px] hero-orb-2"></div>
		<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-indigo-600/8 rounded-full blur-[150px]"></div>
	</div>

	<!-- Partículas de fondo -->
	<div class="absolute inset-0 overflow-hidden pointer-events-none">
		<div class="hero-particle absolute w-1 h-1 bg-blue-400/40 rounded-full" style="top:15%;left:10%;animation-delay:0s"></div>
		<div class="hero-particle absolute w-1.5 h-1.5 bg-violet-400/30 rounded-full" style="top:25%;left:80%;animation-delay:2s"></div>
		<div class="hero-particle absolute w-1 h-1 bg-indigo-400/40 rounded-full" style="top:60%;left:20%;animation-delay:4s"></div>
		<div class="hero-particle absolute w-1.5 h-1.5 bg-blue-400/30 rounded-full" style="top:75%;left:70%;animation-delay:1s"></div>
		<div class="hero-particle absolute w-1 h-1 bg-purple-400/40 rounded-full" style="top:40%;left:90%;animation-delay:3s"></div>
		<div class="hero-particle absolute w-1 h-1 bg-cyan-400/30 rounded-full" style="top:85%;left:45%;animation-delay:5s"></div>
	</div>

	<div class="max-w-7xl mx-auto px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-12 gap-16 items-center relative z-10 py-20">
		<!-- Contenido principal -->
		<div class="lg:col-span-7 space-y-8 hero-content">
			<!-- Badge de disponibilidad -->
			<div class="inline-flex items-center gap-2.5 bg-emerald-500/10 text-emerald-400 px-5 py-2.5 rounded-full text-sm font-medium border border-emerald-500/20 backdrop-blur-sm hero-fade-up" style="animation-delay:0.1s">
				<span class="relative flex h-2.5 w-2.5">
					<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
					<span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-400"></span>
				</span>
				Available for new projects
			</div>
			
			<!-- Subtítulo con línea decorativa -->
			<div class="flex items-center gap-3 hero-fade-up" style="animation-delay:0.2s">
				<div class="h-px w-8 bg-gradient-to-r from-blue-500 to-transparent"></div>
				<span class="text-sm font-semibold tracking-[0.2em] uppercase text-slate-400">Full Stack Developer</span>
			</div>

			<!-- Título principal -->
			<div class="space-y-5 hero-fade-up" style="animation-delay:0.3s">
				<h1 class="text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-bold leading-[0.95] tracking-tight">
					Hi, I'm
					<br />
					<span class="hero-gradient-text">Franco</span>
					<span class="hero-gradient-text">Gaggero</span>
				</h1>
				<p class="text-lg lg:text-xl text-slate-400 leading-relaxed max-w-xl">
					Building <span class="text-slate-200 font-medium">robust digital experiences</span> with modern technologies, clean architecture and a passion for continuous improvement.
				</p>
			</div>
			
			<!-- CTAs principales -->
			<div class="flex flex-col sm:flex-row gap-4 hero-fade-up" style="animation-delay:0.5s">
				<a href="#contact" 
				   class="group relative bg-gradient-to-r from-blue-600 to-violet-600 text-white px-8 py-4 rounded-xl font-semibold transition-all duration-300 hover:shadow-2xl hover:shadow-blue-600/25 hover:-translate-y-1 flex items-center justify-center gap-2 overflow-hidden">
					<span class="absolute inset-0 bg-gradient-to-r from-blue-500 to-violet-500 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
					<span class="relative">Let's work together</span>
					<svg class="w-4 h-4 relative transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
					</svg>
				</a>
				<a href="#about" 
				   class="group border border-slate-700 text-slate-300 px-8 py-4 rounded-xl font-semibold transition-all duration-300 hover:border-slate-500 hover:text-white hover:bg-white/5 hover:-translate-y-1 backdrop-blur-sm flex items-center justify-center gap-2">
					View my work
					<svg class="w-4 h-4 transition-transform group-hover:translate-y-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
					</svg>
				</a>
			</div>
			
			<!-- Social links -->
			<div class="flex items-center gap-4 pt-6 hero-fade-up" style="animation-delay:0.6s">
				<div class="flex gap-3">
					<!-- GitHub -->
					<a href="https://github.com/francogaggero" target="_blank" rel="noopener noreferrer"
					   class="social-btn group relative w-12 h-12 rounded-xl flex items-center justify-center transition-all duration-400 hover:-translate-y-2"
					   style="--btn-color: 255,255,255; --btn-glow: rgba(255,255,255,0.15)">
						<div class="absolute inset-0 rounded-xl bg-white/[0.04] border border-white/10 group-hover:bg-white/[0.12] group-hover:border-white/25 transition-all duration-400"></div>
						<div class="absolute inset-0 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-400 shadow-[0_8px_30px_var(--btn-glow)]"></div>
						<svg class="w-5 h-5 text-slate-400 group-hover:text-white transition-colors duration-300 relative z-10" fill="currentColor" viewBox="0 0 24 24">
							<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
						</svg>
						<span class="social-tooltip">GitHub</span>
					</a>
					<!-- LinkedIn -->
					<a href="https://www.linkedin.com/in/francogaggero/" target="_blank" rel="noopener noreferrer"
					   class="social-btn group relative w-12 h-12 rounded-xl flex items-center justify-center transition-all duration-400 hover:-translate-y-2"
					   style="--btn-color: 59,130,246; --btn-glow: rgba(59,130,246,0.25)">
						<div class="absolute inset-0 rounded-xl bg-blue-500/[0.06] border border-blue-500/15 group-hover:bg-blue-500/20 group-hover:border-blue-400/40 transition-all duration-400"></div>
						<div class="absolute inset-0 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-400 shadow-[0_8px_30px_var(--btn-glow)]"></div>
						<svg class="w-5 h-5 text-blue-400/70 group-hover:text-blue-400 transition-colors duration-300 relative z-10" fill="currentColor" viewBox="0 0 24 24">
							<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
						</svg>
						<span class="social-tooltip">LinkedIn</span>
					</a>
					<!-- Email -->
					<a href="mailto:gaggero25@gmail.com" 
					   class="social-btn group relative w-12 h-12 rounded-xl flex items-center justify-center transition-all duration-400 hover:-translate-y-2"
					   style="--btn-color: 139,92,246; --btn-glow: rgba(139,92,246,0.25)">
						<div class="absolute inset-0 rounded-xl bg-violet-500/[0.06] border border-violet-500/15 group-hover:bg-violet-500/20 group-hover:border-violet-400/40 transition-all duration-400"></div>
						<div class="absolute inset-0 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-400 shadow-[0_8px_30px_var(--btn-glow)]"></div>
						<svg class="w-5 h-5 text-violet-400/70 group-hover:text-violet-400 transition-colors duration-300 relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
						</svg>
						<span class="social-tooltip">Email</span>
					</a>
				</div>
				<div class="h-6 w-px bg-gradient-to-b from-transparent via-slate-600 to-transparent"></div>
				<span class="text-slate-500 text-sm font-medium tracking-wide">Let's connect</span>
			</div>
		</div>
		
		<!-- Imagen de perfil con tarjeta glassmorphism -->
		<div class="lg:col-span-5 flex justify-center lg:justify-end hero-fade-up" style="animation-delay:0.4s">
			<div class="relative group">
				<!-- Glow detrás de la imagen -->
				<div class="absolute -inset-4 bg-gradient-to-r from-blue-600/20 via-violet-600/20 to-indigo-600/20 rounded-[2rem] blur-2xl opacity-60 group-hover:opacity-80 transition-opacity duration-700"></div>
				
				<!-- Imagen principal -->
				<div class="relative w-72 h-72 sm:w-80 sm:h-80 lg:w-[22rem] lg:h-[22rem] rounded-2xl overflow-hidden ring-1 ring-white/10 shadow-2xl transition-transform duration-500 group-hover:scale-[1.02]">
					<img src="/images/portada.jpeg" alt="Franco Gaggero" 
						 class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
					
					<!-- Overlay gradiente -->
					<div class="absolute inset-0 bg-gradient-to-t from-slate-950/60 via-transparent to-transparent"></div>
					
					<!-- Nombre overlay inferior -->
					<div class="absolute bottom-0 left-0 right-0 p-5">
						<div class="flex items-center gap-2">
							<div class="w-2 h-2 bg-emerald-400 rounded-full"></div>
							<span class="text-white/90 text-sm font-medium">Franco Gaggero</span>
						</div>
					</div>
				</div>
				
				<!-- Tarjeta flotante: código -->
				<div class="absolute -top-5 -left-5 bg-slate-900/90 backdrop-blur-xl border border-white/10 rounded-xl px-4 py-3 shadow-2xl hero-float">
					<div class="flex items-center gap-2 mb-1.5">
						<div class="w-2 h-2 rounded-full bg-red-400"></div>
						<div class="w-2 h-2 rounded-full bg-yellow-400"></div>
						<div class="w-2 h-2 rounded-full bg-green-400"></div>
					</div>
					<code class="text-xs text-slate-300">
						<span class="text-violet-400">const</span> <span class="text-blue-300">dev</span> = <span class="text-emerald-400">"Franco"</span>;
					</code>
				</div>

				<!-- Tarjeta flotante: experiencia -->
				<div class="absolute -bottom-4 -right-4 bg-slate-900/90 backdrop-blur-xl border border-white/10 rounded-xl px-4 py-3 shadow-2xl hero-float-delayed">
					<div class="flex items-center gap-3">
						<div class="w-9 h-9 bg-gradient-to-br from-blue-500 to-violet-500 rounded-lg flex items-center justify-center">
							<svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
							</svg>
						</div>
						<div>
							<p class="text-white text-sm font-semibold">2+ Years</p>
							<p class="text-slate-400 text-xs">Experience</p>
						</div>
					</div>
				</div>

				<!-- Badge tech flotante -->
				<div class="absolute top-1/2 -right-8 -translate-y-1/2 bg-slate-900/90 backdrop-blur-xl border border-white/10 rounded-full w-14 h-14 flex items-center justify-center shadow-2xl hero-float-slow">
					<svg class="w-6 h-6 text-blue-400" fill="currentColor" viewBox="0 0 24 24">
						<path d="M14.23 12.004a2.236 2.236 0 0 1-2.235 2.236 2.236 2.236 0 0 1-2.236-2.236 2.236 2.236 0 0 1 2.235-2.236 2.236 2.236 0 0 1 2.236 2.236zm2.648-10.69c-1.346 0-3.107.96-4.888 2.622-1.78-1.653-3.542-2.602-4.887-2.602-.31 0-.594.068-.84.182-.79.378-1.194 1.334-1.194 2.834 0 1.097.345 2.394.94 3.78-.643.283-1.2.588-1.66.914C2.248 10.57 1.5 12.074 1.5 13.162c0 1.744 1.59 3.092 4.16 3.8-.196.77-.296 1.497-.296 2.15 0 1.503.404 2.457 1.194 2.837.247.113.531.18.84.18 1.347 0 3.107-.948 4.889-2.598 1.78 1.65 3.54 2.598 4.887 2.598.31 0 .594-.067.84-.18.79-.38 1.194-1.334 1.194-2.837 0-.655-.1-1.382-.296-2.15 2.57-.71 4.16-2.058 4.16-3.801 0-1.088-.747-2.592-2.85-4.117a14.855 14.855 0 0 0-1.66-.914c.596-1.386.94-2.683.94-3.78 0-1.5-.404-2.456-1.194-2.834a1.683 1.683 0 0 0-.84-.182z"/>
					</svg>
				</div>
			</div>
		</div>
	</div>

	<!-- Scroll indicator -->
	<div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 hero-fade-up" style="animation-delay:1s">
		<span class="text-slate-500 text-xs tracking-widest uppercase">Scroll</span>
		<div class="w-5 h-8 border border-slate-600 rounded-full flex justify-center pt-1.5">
			<div class="w-1 h-2 bg-slate-400 rounded-full scroll-dot"></div>
		</div>
	</div>

	<!-- GradualBlur transition -->
	<GradualBlur client:visible target="parent" position="bottom" height="4rem" strength={1.5} divCount={4} curve="ease-in" exponential opacity={0.6} />
</section>

<style>
	/* Gradient text animado */
	.hero-gradient-text {
		background: linear-gradient(135deg, #60a5fa, #a78bfa, #818cf8, #60a5fa);
		background-size: 300% 300%;
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
		animation: hero-gradient-shift 6s ease-in-out infinite;
	}

	@keyframes hero-gradient-shift {
		0%, 100% { background-position: 0% 50%; }
		50% { background-position: 100% 50%; }
	}

	/* Fade up animation */
	.hero-fade-up {
		opacity: 0;
		transform: translateY(24px);
		animation: hero-fade-up-anim 0.8s ease-out forwards;
	}

	@keyframes hero-fade-up-anim {
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	/* Floating cards */
	.hero-float {
		animation: hero-float-anim 5s ease-in-out infinite;
	}
	.hero-float-delayed {
		animation: hero-float-anim 5s ease-in-out infinite 1.5s;
	}
	.hero-float-slow {
		animation: hero-float-anim 7s ease-in-out infinite 0.8s;
	}

	@keyframes hero-float-anim {
		0%, 100% { transform: translateY(0px); }
		50% { transform: translateY(-12px); }
	}

	/* Orb animations */
	.hero-orb-1 {
		animation: hero-orb-drift 12s ease-in-out infinite;
	}
	.hero-orb-2 {
		animation: hero-orb-drift 15s ease-in-out infinite reverse;
	}

	@keyframes hero-orb-drift {
		0%, 100% { transform: translate(0, 0); }
		33% { transform: translate(30px, -20px); }
		66% { transform: translate(-20px, 15px); }
	}

	/* Particles */
	.hero-particle {
		animation: hero-particle-float 8s ease-in-out infinite;
	}

	@keyframes hero-particle-float {
		0%, 100% { transform: translateY(0) scale(1); opacity: 0.4; }
		50% { transform: translateY(-30px) scale(1.5); opacity: 0.8; }
	}

	/* Scroll indicator */
	.scroll-dot {
		animation: hero-scroll-dot 2s ease-in-out infinite;
	}

	@keyframes hero-scroll-dot {
		0% { transform: translateY(0); opacity: 1; }
		50% { transform: translateY(6px); opacity: 0.3; }
		100% { transform: translateY(0); opacity: 1; }
	}

	/* Social buttons */
	.social-btn {
		perspective: 600px;
	}
	.social-btn:hover {
		transform: translateY(-8px);
	}
	.social-tooltip {
		position: absolute;
		bottom: -32px;
		left: 50%;
		transform: translateX(-50%) translateY(4px);
		background: rgba(15, 23, 42, 0.9);
		backdrop-filter: blur(8px);
		color: #e2e8f0;
		font-size: 0.7rem;
		font-weight: 500;
		padding: 4px 10px;
		border-radius: 6px;
		border: 1px solid rgba(255,255,255,0.1);
		white-space: nowrap;
		opacity: 0;
		pointer-events: none;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	}
	.social-btn:hover .social-tooltip {
		opacity: 1;
		transform: translateX(-50%) translateY(0);
	}
</style>


