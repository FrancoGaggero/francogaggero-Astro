---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Franco Gaggero - Projects">

	<main>
		<!-- Hero Section - Dark Premium -->
		<section class="relative py-28 lg:py-36 bg-slate-950 overflow-hidden">
			<!-- Grid pattern -->
			<div class="absolute inset-0 bg-[linear-gradient(rgba(148,163,184,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(148,163,184,0.03)_1px,transparent_1px)] bg-[size:60px_60px]"></div>
			<!-- Gradient orbs -->
			<div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-blue-600/10 rounded-full blur-[120px]"></div>
			<div class="absolute bottom-0 right-1/4 w-[400px] h-[400px] bg-violet-600/10 rounded-full blur-[120px]"></div>

			<div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">
				<!-- Back + Badge row -->
				<div class="flex items-center justify-center gap-4 mb-10 proj-fade-up" style="animation-delay:0.1s">
					<a href="/" class="inline-flex items-center gap-2 bg-white/5 text-slate-400 px-4 py-2 rounded-full text-sm font-medium border border-white/10 backdrop-blur-sm hover:bg-white/10 hover:text-white transition-all duration-300">
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
						</svg>
						Back Home
					</a>
					<div class="inline-flex items-center gap-2 bg-white/5 text-slate-400 px-4 py-2 rounded-full text-sm font-medium border border-white/10 backdrop-blur-sm">
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
						</svg>
						My Portfolio
					</div>
				</div>

				<!-- Título -->
				<div class="text-center proj-fade-up" style="animation-delay:0.2s">
					<h1 class="text-5xl sm:text-6xl lg:text-8xl font-bold leading-[0.95] tracking-tight text-white mb-6">
						Featured
						<span class="block bg-gradient-to-r from-blue-400 via-violet-400 to-indigo-400 bg-clip-text text-transparent proj-gradient-text">Projects</span>
					</h1>
					<p class="text-lg lg:text-xl text-slate-400 leading-relaxed max-w-2xl mx-auto mb-12">
						A curated collection of full-stack solutions, web experiences, and innovative applications I've built.
					</p>
				</div>

				<!-- Stats -->
				<div class="flex flex-col sm:flex-row items-center justify-center gap-8 sm:gap-12 proj-fade-up" style="animation-delay:0.3s">
					<div class="flex items-center gap-3">
						<div class="w-10 h-10 bg-blue-500/15 border border-blue-500/20 rounded-xl flex items-center justify-center">
							<svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
							</svg>
						</div>
						<div>
							<div class="text-xl font-bold text-white">10+</div>
							<div class="text-xs text-slate-500 uppercase tracking-wider">Projects</div>
						</div>
					</div>
					<div class="w-px h-10 bg-slate-800 hidden sm:block"></div>
					<div class="flex items-center gap-3">
						<div class="w-10 h-10 bg-violet-500/15 border border-violet-500/20 rounded-xl flex items-center justify-center">
							<svg class="w-5 h-5 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
							</svg>
						</div>
						<div>
							<div class="text-xl font-bold text-white">15+</div>
							<div class="text-xs text-slate-500 uppercase tracking-wider">Technologies</div>
						</div>
					</div>
					<div class="w-px h-10 bg-slate-800 hidden sm:block"></div>
					<div class="flex items-center gap-3">
						<div class="w-10 h-10 bg-emerald-500/15 border border-emerald-500/20 rounded-xl flex items-center justify-center">
							<svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
							</svg>
						</div>
						<div>
							<div class="text-xl font-bold text-white">100%</div>
							<div class="text-xs text-slate-500 uppercase tracking-wider">Satisfaction</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Projects Grid -->
		<section class="py-24 bg-slate-950 relative overflow-hidden">
			<!-- Decorative top edge -->
			<div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
			
			<div class="max-w-7xl mx-auto px-6 lg:px-8">
				<!-- Section label -->
				<div class="flex items-center gap-3 mb-12 proj-fade-up">
					<div class="h-px flex-1 bg-gradient-to-r from-white/10 to-transparent"></div>
					<span class="text-xs font-bold tracking-[0.2em] uppercase text-slate-400">All Projects</span>
					<div class="h-px flex-1 bg-gradient-to-l from-white/10 to-transparent"></div>
				</div>
				
				<!-- Grid de proyectos -->
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-20">

					<!-- Proyecto 1: E-commerce Platform -->
					<div class="group relative bg-white/5 backdrop-blur-xl rounded-2xl overflow-hidden border border-white/10 hover:border-white/20 shadow-sm hover:shadow-2xl hover:shadow-blue-500/10 transition-all duration-500 hover:-translate-y-1 proj-fade-up">
						<div class="relative overflow-hidden">
							<div class="h-56 lg:h-64 bg-gradient-to-br from-blue-500 via-purple-500 to-indigo-600 flex items-center justify-center transition-transform duration-700 group-hover:scale-105">
								<div class="text-white/90 text-7xl transition-transform duration-500 group-hover:scale-110 group-hover:rotate-3">🛒</div>
							</div>
							<div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
							<!-- Featured badge -->
							<div class="absolute top-4 left-4 bg-white/10 backdrop-blur-sm rounded-lg px-3 py-1.5 text-xs font-bold text-white border border-white/20 uppercase tracking-wider shadow-sm">
								Featured
							</div>
							<!-- Number -->
							<div class="absolute bottom-4 right-4 text-white/20 text-6xl font-black">01</div>
						</div>
						
						<div class="p-7">
							<div class="flex items-center gap-2 flex-wrap mb-4">
								<span class="px-2.5 py-1 bg-blue-500/20 text-blue-400 rounded-lg text-xs font-semibold">Web</span>
								<span class="px-2.5 py-1 bg-red-500/20 text-red-400 rounded-lg text-xs font-semibold">PHP</span>
								<span class="px-2.5 py-1 bg-orange-500/20 text-orange-400 rounded-lg text-xs font-semibold">Laravel</span>
								<span class="px-2.5 py-1 bg-yellow-500/20 text-yellow-400 rounded-lg text-xs font-semibold">JavaScript</span>
							</div>
							
							<h3 class="text-xl font-bold text-white mb-2 group-hover:text-blue-400 transition-colors">E-commerce Platform</h3>
							<p class="text-slate-400 text-sm leading-relaxed mb-5">
								Full-stack e-commerce solution with customer authentication, shopping cart, and admin panel. Built with modern web technologies for optimal UX and sales conversion.
							</p>
							
							<div class="flex items-center gap-3 pt-4 border-t border-white/10">
								<a href="https://github.com/FrancoGaggero/Nakama-E-commerce" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-medium text-slate-400 hover:text-white transition-colors">
									<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
									Source Code
								</a>
							</div>
						</div>
					</div>
					
					<!-- Proyecto 2: Landing Page Orange Studio -->
					<div class="group relative bg-white/5 backdrop-blur-xl rounded-2xl overflow-hidden border border-white/10 hover:border-white/20 shadow-sm hover:shadow-2xl hover:shadow-orange-500/10 transition-all duration-500 hover:-translate-y-1 proj-fade-up">
						<div class="relative overflow-hidden">
							<div class="h-56 lg:h-64 bg-gradient-to-br from-orange-500 via-pink-500 to-red-600">
								<img src="/images/orangestudio.png" alt="Orange Studio Landing Page" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105">
							</div>
							<div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
							<div class="absolute bottom-4 right-4 text-white/20 text-6xl font-black">02</div>
						</div>
						
						<div class="p-7">
							<div class="flex items-center gap-2 flex-wrap mb-4">
								<span class="px-2.5 py-1 bg-orange-500/20 text-orange-400 rounded-lg text-xs font-semibold">Web</span>
								<span class="px-2.5 py-1 bg-purple-500/20 text-purple-400 rounded-lg text-xs font-semibold">Astro</span>
								<span class="px-2.5 py-1 bg-cyan-500/20 text-cyan-400 rounded-lg text-xs font-semibold">Tailwind</span>
								<span class="px-2.5 py-1 bg-yellow-500/20 text-yellow-400 rounded-lg text-xs font-semibold">JavaScript</span>
							</div>
							
							<h3 class="text-xl font-bold text-white mb-2 group-hover:text-orange-400 transition-colors">Orange Studio Games</h3>
							<p class="text-slate-400 text-sm leading-relaxed mb-5">
								Modern, responsive landing page built with Astro and Tailwind CSS. Features clean design, smooth animations, and optimized performance.
							</p>
							
							<div class="flex items-center gap-4 pt-4 border-t border-white/10">
								<a href="https://orangestudiogames.netlify.app/" class="inline-flex items-center gap-2 text-sm font-medium text-emerald-400 hover:text-emerald-300 transition-colors" target="_blank" rel="noopener noreferrer">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
									Live Site
								</a>
								<a href="https://github.com/FrancoGaggero/Orange-Studio-Games" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-medium text-slate-400 hover:text-white transition-colors">
									<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
									Source Code
								</a>
							</div>
						</div>
					</div>

					<!-- Proyecto 3: Portfolio Valentina Bozzone -->
					<div class="group relative bg-white/5 backdrop-blur-xl rounded-2xl overflow-hidden border border-white/10 hover:border-white/20 shadow-sm hover:shadow-2xl hover:shadow-green-500/10 transition-all duration-500 hover:-translate-y-1 proj-fade-up">
						<div class="relative overflow-hidden">
							<div class="h-56 lg:h-64 bg-gradient-to-br from-green-500 via-emerald-500 to-teal-600">
								<img src="/images/valentinabozzone.png" alt="Portfolio Website Valentina Bozzone" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105">
							</div>
							<div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
							<div class="absolute bottom-4 right-4 text-white/20 text-6xl font-black">03</div>
						</div>
						
						<div class="p-7">
							<div class="flex items-center gap-2 flex-wrap mb-4">
								<span class="px-2.5 py-1 bg-green-500/20 text-green-400 rounded-lg text-xs font-semibold">Web</span>
								<span class="px-2.5 py-1 bg-purple-500/20 text-purple-400 rounded-lg text-xs font-semibold">Astro</span>
								<span class="px-2.5 py-1 bg-cyan-500/20 text-cyan-400 rounded-lg text-xs font-semibold">Tailwind</span>
								<span class="px-2.5 py-1 bg-yellow-500/20 text-yellow-400 rounded-lg text-xs font-semibold">JavaScript</span>
							</div>
							
							<h3 class="text-xl font-bold text-white mb-2 group-hover:text-emerald-400 transition-colors">Portfolio Valentina Bozzone</h3>
							<p class="text-slate-400 text-sm leading-relaxed mb-5">
								Personal portfolio website showcasing projects, skills, and experience. Built with a focus on user experience and modern design principles.
							</p>
							
							<div class="flex items-center gap-4 pt-4 border-t border-white/10">
								<a href="https://valenbozzone.netlify.app/" class="inline-flex items-center gap-2 text-sm font-medium text-emerald-400 hover:text-emerald-300 transition-colors" target="_blank" rel="noopener noreferrer">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
									Live Site
								</a>
								<a href="https://github.com/francogaggero" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-medium text-slate-400 hover:text-white transition-colors">
									<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
									Source Code
								</a>
							</div>
						</div>
					</div>

					<!-- Proyecto 4: TaskManager Pro -->
					<div class="group relative bg-white/5 backdrop-blur-xl rounded-2xl overflow-hidden border border-white/10 hover:border-white/20 shadow-sm hover:shadow-2xl hover:shadow-amber-500/10 transition-all duration-500 hover:-translate-y-1 proj-fade-up">
						<div class="relative overflow-hidden">
							<div class="h-56 lg:h-64 bg-gradient-to-br from-amber-500 via-orange-500 to-red-500">
								<img src="/images/taskmanager.png" alt="TaskManager Pro" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105">
							</div>
							<div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
							<div class="absolute bottom-4 right-4 text-white/20 text-6xl font-black">04</div>
						</div>
						
						<div class="p-7">
							<div class="flex items-center gap-2 flex-wrap mb-4">
								<span class="px-2.5 py-1 bg-blue-500/20 text-blue-400 rounded-lg text-xs font-semibold">React</span>
								<span class="px-2.5 py-1 bg-white/10 text-slate-400 rounded-lg text-xs font-semibold">Express</span>
								<span class="px-2.5 py-1 bg-white/15 text-white rounded-lg text-xs font-semibold">Next.js</span>
								<span class="px-2.5 py-1 bg-indigo-500/20 text-indigo-400 rounded-lg text-xs font-semibold">Prisma</span>
							</div>
							
							<h3 class="text-xl font-bold text-white mb-2 group-hover:text-amber-400 transition-colors">TaskManager Pro</h3>
							<p class="text-slate-400 text-sm leading-relaxed mb-5">
								Full-stack task management app with React & Next.js frontend deployed on Vercel, Express API hosted on Render, and PostgreSQL database on Neon. Features Prisma ORM, responsive UI, and real-time task tracking.
							</p>
							
							<div class="flex items-center gap-4 pt-4 border-t border-white/10">
								<a href="https://frontend-navy-sigma-96.vercel.app/" class="inline-flex items-center gap-2 text-sm font-medium text-emerald-400 hover:text-emerald-300 transition-colors" target="_blank" rel="noopener noreferrer">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
									Live Site
								</a>
								<a href="https://github.com/FrancoGaggero/TaskManager" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-medium text-slate-400 hover:text-white transition-colors">
									<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
									Source Code
								</a>
							</div>
						</div>
					</div>

					<!-- Proyecto 5: Clean S.A (Full Width) -->
					<div class="lg:col-span-2 group relative bg-white/5 backdrop-blur-xl rounded-2xl overflow-hidden border border-white/10 hover:border-white/20 shadow-sm hover:shadow-2xl hover:shadow-emerald-500/10 transition-all duration-500 hover:-translate-y-1 proj-fade-up">
						<div class="grid grid-cols-1 lg:grid-cols-2">
							<div class="relative overflow-hidden">
								<div class="h-56 lg:h-full min-h-[280px] bg-gradient-to-br from-emerald-500 via-teal-500 to-cyan-600">
									<img src="/images/claeanSA.png" alt="Clean S.A" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105">
								</div>
								<div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent lg:bg-gradient-to-r lg:from-transparent lg:via-transparent lg:to-black/10"></div>
